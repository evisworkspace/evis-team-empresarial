// EVIS Team Empresarial — Schema do núcleo mínimo
// Fonte: docs/06_modelagem_relacional_nucleo_minimo.md (VALIDADO)
// Lote 1 do Despacho 007: schema validável, sem migration, sem banco conectado.
//
// Convenções:
// - Modelos em pt + @@map para snake_case (idioma pt/en é decisão futura — docs/06 §12)
// - Campos de domínio controlado como String com comentário do domínio
//   (forma final ENUM vs CHECK vs tabela é decisão ADIADA — docs/06 §6 e §12)
// - empresa_id obrigatório nas 8 tabelas subordinadas (multi-tenancy D1)
// - rastreio_auditoria é append-only: só created_at, sem updated_at/deleted_at

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// NÚCLEO EVIS — 9 tabelas (docs/06)
// ============================================================

/// Tenant raiz — não carrega empresa_id de si mesma.
model Empresa {
  id          String    @id @default(uuid()) @db.Uuid
  nome        String
  tipoPessoa  String    @map("tipo_pessoa") // domínio: PF | PJ
  documento   String?
  razaoSocial String?   @map("razao_social")
  email       String?
  celular     String?
  isWhatsapp  Boolean?  @default(false) @map("is_whatsapp")
  tipoEmpresa String?   @map("tipo_empresa")
  logo        String?
  descricao   String?   @db.Text
  status      String // domínio: ativo | inativo
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  usuarios              Usuario[]
  clientes              Cliente[]
  projetos              Projeto[]
  configs               ProjetoConfig[]
  itensOrcamento        ProjetoItemOrcamento[]
  fornecedores          Fornecedor[]
  tarefas               Tarefa[]
  lancamentos           LancamentoFinanceiro[]
  rastreios             RastreioAuditoria[]
  atividades            ProjetoAtividade[]
  anotacoes             Anotacao[]
  statusProjetos        StatusProjeto[]
  users                 User[] // Auth.js — vínculo tenant do usuário autenticado
  convites              ConviteEquipe[]
  grupos                GrupoItem[]
  categoriasItem        CategoriaItem[]
  unidades              UnidadeMedida[]
  categoriasFinanceiras CategoriaFinanceira[]
  centrosDeCusto        CentroDeCusto[]
  itensBiblioteca       ItemBiblioteca[]
  medicoes              Medicao[]
  diariosObra           DiarioDeObra[]
  diariosItemHITL       DiarioItemHITL[]
  agendaItens           AgendaItem[]
  ottoSessoes           OttoSessao[]
  ottoDocumentos        OttoDocumento[]
  ottoDecisoes          OttoDecisao[]
  ottoItensEAP          OttoItemEAP[]

  @@map("empresa")
}

/// Operador humano (HITL) — identifica o humano na trilha de auditoria.
model Usuario {
  id         String    @id @default(uuid()) @db.Uuid
  empresaId  String    @map("empresa_id") @db.Uuid
  nome       String
  email      String
  perfil     String // domínio: admin | operador | viewer
  status     String // domínio: ativo | inativo
  // Vínculo explícito com a identidade Auth.js (decisão 9.1). Email é apenas dado de
  // apoio, NUNCA o vínculo principal. Relação 1:1 (MVP): um User ↔ um usuario.
  authUserId String?   @unique @map("auth_user_id")
  cpf        String?
  telefone   String?
  foto       String? // URL Vercel Blob — avatar pessoal (prevalece sobre User.image do Google)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  empresa            Empresa             @relation(fields: [empresaId], references: [id])
  authUser           User?               @relation(fields: [authUserId], references: [id])
  tarefasResponsavel Tarefa[]            @relation("TarefaResponsavelUsuario")
  rastreios          RastreioAuditoria[]

  @@unique([empresaId, email])
  @@index([empresaId])
  @@map("usuario")
}

/// Convite de e-mail para adicionar membro à equipe — token de aceite único.
model ConviteEquipe {
  id        String    @id @default(uuid()) @db.Uuid
  empresaId String    @map("empresa_id") @db.Uuid
  email     String
  perfil    String // domínio: admin | membro
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@map("convite_equipe")
}

/// Destinatário do serviço — pode existir antes de qualquer projeto.
model Cliente {
  id             String    @id @default(uuid()) @db.Uuid
  empresaId      String    @map("empresa_id") @db.Uuid
  nome           String
  telefone       String?
  tipoPessoa     String?   @map("tipo_pessoa") // domínio: PF | PJ
  origemContato  String?   @map("origem_contato")
  razaoSocial    String?   @map("razao_social")
  email          String?
  cpfCnpj        String?   @map("cpf_cnpj")
  cep            String?
  rua            String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  estado         String?
  observacoes    String?
  rg             String?   @map("rg")
  dataNascimento DateTime? @map("data_nascimento")
  status         String // domínio: ativo | inativo
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  empresa  Empresa   @relation(fields: [empresaId], references: [id])
  projetos Projeto[]

  @@index([empresaId])
  @@map("cliente")
}

/// Entidade-base única (Oportunidade + Obra), discriminada por stage.
model Projeto {
  id                   String    @id @default(uuid()) @db.Uuid
  empresaId            String    @map("empresa_id") @db.Uuid
  clienteId            String    @map("cliente_id") @db.Uuid
  codigoSequencial     String?   @map("codigo_sequencial") @db.VarChar(20) // gerado pelo sistema: YYYY-NNN
  numeroObra           String?   @map("numero_obra") // UNIQUE por empresa quando não nulo — atribuído manualmente pelo usuário
  titulo               String
  descricao            String?
  stage                String // domínio: oportunidade | obra
  statusInterno        String    @map("status_interno") // domínio por stage (docs/06 §6)
  origem               String?
  tipoObra             String?   @map("tipo_obra") // residencial | comercial | industrial | reforma | outro
  prioridade           String? // baixa | media | alta | urgente
  metragemEstimada     Decimal?  @map("metragem_estimada") @db.Decimal(10, 2)
  valorEstimado        Decimal?  @map("valor_estimado") @db.Decimal(15, 2)
  valorGanhoEstimativa Decimal?  @map("valor_ganho_estimativa") @db.Decimal(15, 2)
  enderecoObra         String?   @map("endereco_obra")
  dataInicioEstimada   DateTime? @map("data_inicio_estimada") @db.Date
  dataDeGanho          DateTime? @map("data_de_ganho") @db.Date
  cepObra              String?   @map("cep_obra")
  logradouroObra       String?   @map("logradouro_obra")
  numeroEnderecoObra   String?   @map("numero_endereco_obra")
  complementoObra      String?   @map("complemento_obra")
  bairroObra           String?   @map("bairro_obra")
  cidadeObra           String?   @map("cidade_obra")
  estadoObra           String?   @map("estado_obra")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  empresa        Empresa                @relation(fields: [empresaId], references: [id])
  cliente        Cliente                @relation(fields: [clienteId], references: [id])
  itensOrcamento ProjetoItemOrcamento[]
  tarefas        Tarefa[]
  lancamentos    LancamentoFinanceiro[]
  rastreios      RastreioAuditoria[]
  atividades     ProjetoAtividade[]
  anotacoes      Anotacao[]
  medicoes       Medicao[]
  diariosObra    DiarioDeObra[]
  agendaItens    AgendaItem[]
  config         ProjetoConfig?
  ottoSessoes    OttoSessao[]

  @@unique([empresaId, codigoSequencial])
  @@unique([empresaId, numeroObra])
  @@index([empresaId, stage, statusInterno])
  @@index([clienteId])
  @@map("projeto")
}

/// Anotações editáveis vinculadas a oportunidade ou obra.
model Anotacao {
  id             String    @id @default(uuid()) @db.Uuid
  empresaId      String    @map("empresa_id") @db.Uuid
  projetoId      String    @map("projeto_id") @db.Uuid
  titulo         String?   @db.VarChar(200)
  conteudo       String    @db.Text
  visivelCliente Boolean   @default(false) @map("visivel_cliente")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  empresa Empresa @relation(fields: [empresaId], references: [id])
  projeto Projeto @relation(fields: [projetoId], references: [id])

  @@index([projetoId, createdAt])
  @@index([empresaId])
  @@map("anotacao")
}

/// Registro manual de atividades comerciais — ligações, visitas, notas, e-mails.
/// Append-only: não tem updatedAt/deletedAt.
model ProjetoAtividade {
  id        String @id @default(uuid()) @db.Uuid
  empresaId String @map("empresa_id") @db.Uuid
  projetoId String @map("projeto_id") @db.Uuid
  tipo      String // ligacao | visita | email | reuniao | nota | outro
  descricao String

  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id])
  projeto Projeto @relation(fields: [projetoId], references: [id])

  @@index([projetoId, createdAt])
  @@index([empresaId])
  @@map("projeto_atividade")
}

/// Orçamento hierárquico — 3 níveis: nivel → subnivel → composicao (tipo discriminado).
model ProjetoItemOrcamento {
  id        String  @id @default(uuid()) @db.Uuid
  empresaId String  @map("empresa_id") @db.Uuid
  projetoId String  @map("projeto_id") @db.Uuid
  parentId  String? @map("parent_id") @db.Uuid
  posicao   Int     @default(0)
  tipo      String  @db.VarChar(20) // nivel | subnivel | composicao
  nome      String  @db.VarChar(300)
  grupo     String? @db.VarChar(100)

  itemBibliotecaId String? @map("item_biblioteca_id") @db.Uuid
  fornecedorId     String? @map("fornecedor_id") @db.Uuid

  unidade       String?  @db.VarChar(20)
  quantidade    Decimal? @db.Decimal(15, 4)
  custoServicos Decimal? @map("custo_servicos") @db.Decimal(15, 4)
  bdi           Decimal? @db.Decimal(10, 5)
  produtos      Decimal? @db.Decimal(15, 4)
  servicos      Decimal? @db.Decimal(15, 4) // calculado: (custoServicos + produtos) × (1 + bdi/100)

  dataInicioPlano DateTime? @map("data_inicio_plano") @db.Date
  dataFimPlano    DateTime? @map("data_fim_plano") @db.Date
  diasDuracao     Int?      @map("dias_duracao")
  responsavel     String?   @db.VarChar(150)
  statusItem      String?   @map("status_item") @db.VarChar(20) // para_aprovar | aprovado | nao_aprovado

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  empresa        Empresa                @relation(fields: [empresaId], references: [id])
  projeto        Projeto                @relation(fields: [projetoId], references: [id])
  itemBiblioteca ItemBiblioteca?        @relation(fields: [itemBibliotecaId], references: [id])
  fornecedor     Fornecedor?            @relation(fields: [fornecedorId], references: [id])
  parent         ProjetoItemOrcamento?  @relation("SubItens", fields: [parentId], references: [id])
  children       ProjetoItemOrcamento[] @relation("SubItens")
  medicaoItens   MedicaoItem[]

  @@index([projetoId])
  @@index([empresaId])
  @@index([parentId])
  @@index([fornecedorId])
  @@index([statusItem])
  @@map("projeto_item_orcamento")
}

/// Prestador ou fornecedor de material.
model Fornecedor {
  id              String    @id @default(uuid()) @db.Uuid
  empresaId       String    @map("empresa_id") @db.Uuid
  nome            String
  contato         String?
  tipoPessoa      String?   @map("tipo_pessoa")
  razaoSocial     String?   @map("razao_social")
  cpfCnpj         String?   @map("cpf_cnpj")
  tipo            String // domínio: servico | material | ambos
  categorias      String?
  email           String?
  telefone        String?
  site            String?
  nomeResponsavel String?   @map("nome_responsavel")
  nomeContato     String?   @map("nome_contato")
  cep             String?
  rua             String?
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String?
  estado          String?
  status          String // domínio: ativo | inativo
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  empresa         Empresa                @relation(fields: [empresaId], references: [id])
  tarefas         Tarefa[]               @relation("TarefaResponsavelFornecedor")
  lancamentos     LancamentoFinanceiro[]
  itensBiblioteca ItemBiblioteca[]
  itensOrcamento  ProjetoItemOrcamento[]

  @@index([empresaId])
  @@map("fornecedor")
}

/// Unidade mínima de operação — vinculada ao projeto por projeto_id.
model Tarefa {
  id                      String    @id @default(uuid()) @db.Uuid
  empresaId               String    @map("empresa_id") @db.Uuid
  projetoId               String    @map("projeto_id") @db.Uuid
  descricao               String
  status                  String // domínio: aberta | em_andamento | concluida | cancelada
  dataPrevista            DateTime? @map("data_prevista") @db.Date
  responsavelUsuarioId    String?   @map("responsavel_usuario_id") @db.Uuid
  responsavelFornecedorId String?   @map("responsavel_fornecedor_id") @db.Uuid
  origem                  String // domínio: manual | sugerida_ia
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  empresa               Empresa     @relation(fields: [empresaId], references: [id])
  projeto               Projeto     @relation(fields: [projetoId], references: [id])
  responsavelUsuario    Usuario?    @relation("TarefaResponsavelUsuario", fields: [responsavelUsuarioId], references: [id])
  responsavelFornecedor Fornecedor? @relation("TarefaResponsavelFornecedor", fields: [responsavelFornecedorId], references: [id])

  @@index([projetoId, status])
  @@index([empresaId])
  @@index([responsavelUsuarioId])
  @@index([responsavelFornecedorId])
  @@map("tarefa")
}

/// Agenda operacional do sistema — compromissos com data/hora.
model AgendaItem {
  id        String    @id @default(uuid()) @db.Uuid
  empresaId String    @map("empresa_id") @db.Uuid
  projetoId String?   @map("projeto_id") @db.Uuid
  titulo    String    @db.VarChar(200)
  descricao String?   @db.Text
  tipo      String    @default("compromisso") @db.VarChar(40) // compromisso | visita | reuniao | ligacao | follow_up | prazo | entrega | lembrete
  inicio    DateTime
  fim       DateTime?
  status    String    @default("agendado") @db.VarChar(30) // agendado | concluido | cancelado
  origem    String    @default("manual") @db.VarChar(30) // manual | sugerida_ia
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  empresa Empresa  @relation(fields: [empresaId], references: [id])
  projeto Projeto? @relation(fields: [projetoId], references: [id])

  @@index([empresaId, inicio])
  @@index([projetoId, inicio])
  @@map("agenda_item")
}

model GrupoItem {
  id        String    @id @default(uuid()) @db.Uuid
  empresaId String    @map("empresa_id") @db.Uuid
  nome      String
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  empresa Empresa          @relation(fields: [empresaId], references: [id])
  itens   ItemBiblioteca[]

  @@index([empresaId])
  @@map("grupo_item")
}

model CategoriaItem {
  id        String    @id @default(uuid()) @db.Uuid
  empresaId String    @map("empresa_id") @db.Uuid
  nome      String
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  empresa Empresa          @relation(fields: [empresaId], references: [id])
  itens   ItemBiblioteca[]

  @@index([empresaId])
  @@map("categoria_item")
}

model UnidadeMedida {
  id        String    @id @default(uuid()) @db.Uuid
  empresaId String    @map("empresa_id") @db.Uuid
  nome      String
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  empresa Empresa          @relation(fields: [empresaId], references: [id])
  itens   ItemBiblioteca[]

  @@index([empresaId])
  @@map("unidade_medida")
}

model CategoriaFinanceira {
  id        String    @id @default(uuid()) @db.Uuid
  empresaId String    @map("empresa_id") @db.Uuid
  numero    String
  nome      String
  tipo      String // receita | despesa
  grupoDRE  String?   @map("grupo_dre")
  parentId  String?   @map("parent_id") @db.Uuid
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  empresa     Empresa                @relation(fields: [empresaId], references: [id])
  parent      CategoriaFinanceira?   @relation("SubCategorias", fields: [parentId], references: [id])
  filhos      CategoriaFinanceira[]  @relation("SubCategorias")
  lancamentos LancamentoFinanceiro[]

  @@index([empresaId])
  @@index([parentId])
  @@map("categoria_financeira")
}

model CentroDeCusto {
  id        String    @id @default(uuid()) @db.Uuid
  empresaId String    @map("empresa_id") @db.Uuid
  nome      String
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  empresa     Empresa                @relation(fields: [empresaId], references: [id])
  lancamentos LancamentoFinanceiro[]

  @@index([empresaId])
  @@map("centro_de_custo")
}

model ItemBiblioteca {
  id            String   @id @default(uuid()) @db.Uuid
  empresaId     String   @map("empresa_id") @db.Uuid
  codigo        String?  @map("codigo") @db.VarChar(50)
  nome          String   @db.VarChar(200)
  descricao     String?  @db.Text
  tipo          String   @db.VarChar(30)
  ativo         Boolean  @default(true)
  precoUnitario Decimal? @map("preco_unitario") @db.Decimal(15, 4)

  unidadeId    String? @map("unidade_id") @db.Uuid
  grupoId      String? @map("grupo_id") @db.Uuid
  categoriaId  String? @map("categoria_id") @db.Uuid
  fornecedorId String? @map("fornecedor_id") @db.Uuid

  unidade        UnidadeMedida?         @relation(fields: [unidadeId], references: [id])
  grupo          GrupoItem?             @relation(fields: [grupoId], references: [id])
  categoria      CategoriaItem?         @relation(fields: [categoriaId], references: [id])
  fornecedor     Fornecedor?            @relation(fields: [fornecedorId], references: [id])
  empresa        Empresa                @relation(fields: [empresaId], references: [id])
  itensOrcamento ProjetoItemOrcamento[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([empresaId])
  @@index([tipo])
  @@map("item_biblioteca")
}

/// Entrada ou saída básica. "vencido" é estado derivado, não armazenado.
model LancamentoFinanceiro {
  id                    String    @id @default(uuid()) @db.Uuid
  empresaId             String    @map("empresa_id") @db.Uuid
  projetoId             String    @map("projeto_id") @db.Uuid
  fornecedorId          String?   @map("fornecedor_id") @db.Uuid
  categoriaFinanceiraId String?   @map("categoria_financeira_id") @db.Uuid
  centroDeCustoId       String?   @map("centro_de_custo_id") @db.Uuid
  tipo                  String // domínio: entrada | saida
  valor                 Decimal   @db.Decimal(15, 2) // precisão provisória — docs/06 §12 adiado
  dataVencimento        DateTime  @map("data_vencimento") @db.Date
  dataRealizacao        DateTime? @map("data_realizacao") @db.Date // só quando status = realizado
  descricao             String?
  status                String // domínio: previsto | realizado | cancelado
  contaBancaria         String?   @map("conta_bancaria") @db.VarChar(100)
  formaPagamento        String?   @map("forma_pagamento") @db.VarChar(50)
  numeroParcela         Int?      @map("numero_parcela")
  totalParcelas         Int?      @map("total_parcelas")
  valorTotal            Decimal?  @map("valor_total") @db.Decimal(15, 2)
  notaFiscal            String?   @map("nota_fiscal") @db.VarChar(200)
  juros                 Decimal?  @db.Decimal(15, 2)
  multa                 Decimal?  @db.Decimal(15, 2)
  desconto              Decimal?  @db.Decimal(15, 2)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  empresa             Empresa              @relation(fields: [empresaId], references: [id])
  projeto             Projeto              @relation(fields: [projetoId], references: [id])
  fornecedor          Fornecedor?          @relation(fields: [fornecedorId], references: [id])
  categoriaFinanceira CategoriaFinanceira? @relation(fields: [categoriaFinanceiraId], references: [id])
  centroDeCusto       CentroDeCusto?       @relation(fields: [centroDeCustoId], references: [id])

  @@index([projetoId, status])
  @@index([empresaId])
  @@index([fornecedorId])
  @@index([categoriaFinanceiraId])
  @@index([centroDeCustoId])
  @@map("lancamento_financeiro")
}

model ProjetoConfig {
  id         String   @id @default(uuid()) @db.Uuid
  empresaId  String   @map("empresa_id") @db.Uuid
  projetoId  String   @unique @map("projeto_id") @db.Uuid
  bdiPadraoP Decimal  @default(10) @map("bdi_padrao_p") @db.Decimal(10, 2)
  bdiPadraoS Decimal  @default(15) @map("bdi_padrao_s") @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id])
  projeto Projeto @relation(fields: [projetoId], references: [id])

  @@index([empresaId])
  @@map("projeto_config")
}

model OttoSessao {
  id             String    @id @default(uuid()) @db.Uuid
  empresaId      String    @map("empresa_id") @db.Uuid
  projetoId      String    @map("projeto_id") @db.Uuid
  estado         String    @default("rascunho") @db.VarChar(40)
  leituraTecnica String?   @map("leitura_tecnica") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  empresa    Empresa         @relation(fields: [empresaId], references: [id])
  projeto    Projeto         @relation(fields: [projetoId], references: [id])
  documentos OttoDocumento[]
  decisoes   OttoDecisao[]
  itensEAP   OttoItemEAP[]

  @@index([projetoId])
  @@index([empresaId])
  @@index([estado])
  @@map("otto_sessao")
}

model OttoDocumento {
  id           String    @id @default(uuid()) @db.Uuid
  sessaoId     String    @map("sessao_id") @db.Uuid
  empresaId    String    @map("empresa_id") @db.Uuid
  tipo         String    @db.VarChar(20)
  titulo       String    @db.VarChar(300)
  conteudo     String?   @db.Text
  url          String?   @db.VarChar(2000)
  legibilidade String?   @db.VarChar(10)
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  sessao  OttoSessao @relation(fields: [sessaoId], references: [id])
  empresa Empresa    @relation(fields: [empresaId], references: [id])

  @@index([sessaoId])
  @@index([empresaId])
  @@map("otto_documento")
}

model OttoDecisao {
  id           String    @id @default(uuid()) @db.Uuid
  sessaoId     String    @map("sessao_id") @db.Uuid
  empresaId    String    @map("empresa_id") @db.Uuid
  pergunta     String    @db.Text
  resposta     String?   @db.Text
  impacto      String?   @db.VarChar(200)
  status       String    @default("pendente") @db.VarChar(20)
  posicao      Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  respondidaEm DateTime? @map("respondida_em")
  deletedAt    DateTime? @map("deleted_at")

  sessao  OttoSessao @relation(fields: [sessaoId], references: [id])
  empresa Empresa    @relation(fields: [empresaId], references: [id])

  @@index([sessaoId])
  @@index([empresaId])
  @@index([status])
  @@map("otto_decisao")
}

model OttoItemEAP {
  id           String    @id @default(uuid()) @db.Uuid
  sessaoId     String    @map("sessao_id") @db.Uuid
  empresaId    String    @map("empresa_id") @db.Uuid
  parentId     String?   @map("parent_id") @db.Uuid
  posicao      Int       @default(0)
  nivelEAP     Int       @default(1) @map("nivel_eap")
  nome         String    @db.VarChar(300)
  descricao    String?   @db.Text
  unidade      String?   @db.VarChar(20)
  quantidade   Decimal?  @db.Decimal(15, 4)
  statusEscopo String?   @map("status_escopo") @db.VarChar(20)
  natureza     String?   @db.VarChar(30)
  confianca    String?   @db.VarChar(10)
  fonte        String?   @db.VarChar(300)
  aprovado     Boolean   @default(false)
  exportado    Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  sessao   OttoSessao    @relation(fields: [sessaoId], references: [id])
  empresa  Empresa       @relation(fields: [empresaId], references: [id])
  parent   OttoItemEAP?  @relation("SubEAP", fields: [parentId], references: [id])
  children OttoItemEAP[] @relation("SubEAP")

  @@index([sessaoId])
  @@index([empresaId])
  @@index([parentId])
  @@index([nivelEAP])
  @@index([aprovado])
  @@map("otto_item_eap")
}

model Medicao {
  id             String   @id @default(uuid()) @db.Uuid
  empresaId      String   @map("empresa_id") @db.Uuid
  projetoId      String   @map("projeto_id") @db.Uuid
  numero         Int
  dataReferencia DateTime @map("data_referencia") @db.Date
  observacao     String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  empresa Empresa       @relation(fields: [empresaId], references: [id])
  projeto Projeto       @relation(fields: [projetoId], references: [id])
  itens   MedicaoItem[]

  @@unique([projetoId, numero])
  @@index([projetoId])
  @@index([empresaId])
  @@map("medicao")
}

model MedicaoItem {
  id               String   @id @default(uuid()) @db.Uuid
  medicaoId        String   @map("medicao_id") @db.Uuid
  itemOrcamentoId  String   @map("item_orcamento_id") @db.Uuid
  valorMedido      Decimal? @map("valor_medido") @db.Decimal(15, 2)
  quantidadeMedida Decimal? @map("quantidade_medida") @db.Decimal(15, 4)
  percentualMedido Decimal? @map("percentual_medido") @db.Decimal(7, 4)

  medicao       Medicao              @relation(fields: [medicaoId], references: [id])
  itemOrcamento ProjetoItemOrcamento @relation(fields: [itemOrcamentoId], references: [id])

  @@unique([medicaoId, itemOrcamentoId])
  @@index([medicaoId])
  @@index([itemOrcamentoId])
  @@map("medicao_item")
}

/// Registro diário de obra (RDO) — fonte do Canteiro IA.
model DiarioDeObra {
  id         String   @id @default(uuid()) @db.Uuid
  empresaId  String   @map("empresa_id") @db.Uuid
  projetoId  String   @map("projeto_id") @db.Uuid
  numero     Int
  data       DateTime @db.Date
  status     String   @default("rascunho") @db.VarChar(30) // rascunho | processando | concluido
  descricao  String   @db.Text
  processado Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  empresa   Empresa          @relation(fields: [empresaId], references: [id])
  projeto   Projeto          @relation(fields: [projetoId], references: [id])
  itensHITL DiarioItemHITL[]

  @@unique([projetoId, numero])
  @@index([projetoId, data])
  @@index([empresaId])
  @@map("diario_de_obra")
}

/// Itens categorizados pelo Canteiro IA — aguardam HITL.
model DiarioItemHITL {
  id             String    @id @default(uuid()) @db.Uuid
  empresaId      String    @map("empresa_id") @db.Uuid
  diarioId       String    @map("diario_id") @db.Uuid
  tipo           String    @db.VarChar(50) // visita | tarefa | atividade | proxima_demanda | registro_execucao | observacao | problema_obra
  titulo         String    @db.VarChar(300)
  descricao      String?   @db.Text
  prioridade     String?   @db.VarChar(30) // urgente | alta | media | baixa
  percentual     Decimal?  @db.Decimal(7, 4)
  dataSugerida   DateTime? @map("data_sugerida") @db.Date
  confianca      Decimal   @default(0.80) @db.Decimal(3, 2)
  motivoDeteccao String?   @map("motivo_deteccao") @db.VarChar(500)
  status         String    @default("pendente") @db.VarChar(20) // pendente | aprovado | rejeitado

  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa      @relation(fields: [empresaId], references: [id])
  diario  DiarioDeObra @relation(fields: [diarioId], references: [id])

  @@index([diarioId])
  @@index([empresaId, status])
  @@map("diario_item_hitl")
}

/// Camada de auditoria transversal — APPEND-ONLY, imutável.
/// Sem updated_at, sem deleted_at: nunca UPDATE, nunca DELETE.
model RastreioAuditoria {
  id                  String   @id @default(uuid()) @db.Uuid
  empresaId           String   @map("empresa_id") @db.Uuid
  projetoId           String?  @map("projeto_id") @db.Uuid
  entidadeAfetadaTipo String   @map("entidade_afetada_tipo")
  entidadeAfetadaId   String   @map("entidade_afetada_id") @db.Uuid
  eventoTipo          String   @map("evento_tipo") // domínio: criacao | edicao | validacao_ia | rejeicao_ia | conversao_stage | alteracao_status | alteracao_financeiro
  usuarioId           String?  @map("usuario_id") @db.Uuid // null quando gerado pelo sistema
  conteudoSugeridoIa  Json?    @map("conteudo_sugerido_ia") @db.JsonB
  conteudoPersistido  Json     @map("conteudo_persistido") @db.JsonB
  origemInformacao    String?  @map("origem_informacao")
  createdAt           DateTime @default(now()) @map("created_at")

  empresa Empresa  @relation(fields: [empresaId], references: [id])
  projeto Projeto? @relation(fields: [projetoId], references: [id])
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([entidadeAfetadaTipo, entidadeAfetadaId, createdAt])
  @@index([empresaId, projetoId, createdAt])
  @@index([usuarioId])
  @@map("rastreio_auditoria")
}

/// Status customizáveis do kanban por empresa e stage — seed automático no primeiro acesso.
model StatusProjeto {
  id        String   @id @default(uuid()) @db.Uuid
  empresaId String   @map("empresa_id") @db.Uuid
  stage     String // "oportunidade" | "obra"
  slug      String // valor armazenado em Projeto.statusInterno
  label     String
  cor       String   @default("#6b7280")
  ordem     Int
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, stage, slug])
  @@index([empresaId, stage, ordem])
  @@map("status_projeto")
}

// ============================================================
// AUTH.JS / PrismaAdapter — 4 tabelas (esquema oficial do adapter)
// Configuração do Auth.js NÃO entra no Lote 1 — só os modelos.
// User carrega empresaId (multi-tenancy). usuario (HITL) x User: reconciliar no Lote 2.
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  empresaId     String?   @map("empresa_id") @db.Uuid // null até onboarding definir a empresa
  accounts      Account[]
  sessions      Session[]

  empresa Empresa? @relation(fields: [empresaId], references: [id])
  usuario Usuario? // vínculo 1:1 com o usuario EVIS (HITL) — decisão 9.1

  @@index([empresaId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
