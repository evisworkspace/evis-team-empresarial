# EVIS — Variáveis de ambiente (EXEMPLO). NÃO commitar valores reais.
# Copie para .env.local e preencha com seus valores.

# Banco Postgres (Neon) — connection string pooled (Prisma >= 5.10 usa URL única).
# DIRECT_URL e prisma.config.ts ficam adiados (Despacho 006 A4).
DATABASE_URL="postgresql://USUARIO:SENHA@HOST/BANCO?sslmode=require"

# Auth.js v5 — placeholders, sem segredo real. Copie para .env.local e preencha.
# AUTH_SECRET: chave de assinatura do JWT (gere com `npx auth secret`).
AUTH_SECRET=""
# Credenciais do Google OAuth (Google Cloud Console). Convenção Auth.js v5:
# Google() sem args lê AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET automaticamente.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
